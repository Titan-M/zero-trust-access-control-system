ZTAC_ENV=development
ZTAC_DATABASE_URL=sqlite:///./ztac.db
ZTAC_SECRET_KEY=change-this-to-a-long-random-secret
ZTAC_ACCESS_TOKEN_EXPIRE_MINUTES=60
ZTAC_MFA_CHALLENGE_TTL_SECONDS=300
ZTAC_MFA_MAX_ATTEMPTS=3
ZTAC_MFA_DEBUG_MODE=true
ZTAC_CORS_ALLOW_ORIGINS=http://localhost:3000
ZTAC_CORS_ALLOW_CREDENTIALS=true
ZTAC_TRUSTED_HOSTS=localhost,127.0.0.1
ZTAC_ENABLE_HTTPS_REDIRECT=false
ZTAC_LOG_LEVEL=INFO
ZTAC_AUTH_RATE_LIMIT_PER_MINUTE=20
ZTAC_ACCESS_RATE_LIMIT_PER_MINUTE=60
ZTAC_MFA_RATE_LIMIT_PER_MINUTE=20
